# Add your Anthropic API key to enable the LIVE AI assist:
#   - company-side submission evaluation
#   - instant seeker feedback
#   - AI brief drafting
# Without it, the app runs in demo mode (heuristic grading). Copy to .env.local.
ANTHROPIC_API_KEY=

# Optional: override the model. Default is claude-opus-4-8 (most capable).
# For cheaper / faster calls:
# SCHUTZENGEL_MODEL=claude-sonnet-4-6
